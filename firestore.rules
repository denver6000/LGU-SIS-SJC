rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    function isEncoder() {
      return signedIn() && (
        request.auth.token.role == 'encoder' ||
        request.auth.token.encoder == true ||
        request.auth.token.role == 'user' ||
        request.auth.token.user == true
      );
    }

    function isAppUser() {
      return isAdmin() || isEncoder();
    }

    match /students/{studentId} {
      allow read: if isAppUser();
      allow create, update, delete: if false;
    }

    match /trash/{studentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /payoutRecords/{recordId} {
      allow read, write: if isAppUser();
    }

    match /schoolCourses/{recordId} {
      allow read, write: if isAppUser();
    }

    match /barangays/{recordId} {
      allow read, write: if isAppUser();
    }

    match /schools/{recordId} {
      allow read, write: if isAppUser();
    }

    match /courses/{recordId} {
      allow read, write: if isAppUser();
    }

    match /batches/{recordId} {
      allow read, write: if isAppUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
